    "tags": [
      "蒙恬",
      "技能语音"
    ]
  },
  {
    "id": "quote-mengtian-025",
    "heroId": "mengtian",
    "heroName": "蒙恬",
    "text": "言多变则不信，令频改则难从",
    "type": "技能语音",
    "tags": [
      "蒙恬",
      "技能语音"
    ]
  },
  {
