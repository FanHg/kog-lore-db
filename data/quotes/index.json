    "type": "技能语音",
    "tags": [
      "镜",
      "技能语音"
    ]
  },
  {
    "id": "quote-xishi-011",
    "heroId": "xishi",
    "heroName": "西施",
    "text": "常说的话：最有价值之物，给最珍贵之人",
    "type": "移动语音",
    "tags": [
      "西施",
      "移动语音"
    ]
  },
  {
